{
  "name": "api-rate-limiter",
  "version": "1.1.0",
  "description": "Express middleware for API rate limiting with Redis support. Three strategies (fixed/sliding/token-bucket), presets, IETF draft-7 headers, fail-open/closed, structured logger.",
  "main": "src/index.js",
  "scripts": {
    "start": "node examples/basic.js",
    "dev": "node examples/basic.js",
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "test:ci": "jest --coverage --ci --forceExit",
    "example": "node examples/basic.js",
    "example:redis": "node examples/with-redis.js",
    "example:advanced": "node examples/advanced.js",
    "example:presets": "node examples/presets.js"
  },
  "keywords": [
    "express",
    "rate-limit",
    "rate-limiter",
    "middleware",
    "redis",
    "api",
    "throttle",
    "sliding-window",
    "token-bucket",
    "fixed-window",
    "ietf-draft-7",
    "ratelimit-headers"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 85,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
