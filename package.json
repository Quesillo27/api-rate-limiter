{
  "name": "api-rate-limiter",
  "version": "1.0.0",
  "description": "Express middleware for API rate limiting with Redis support. Multiple strategies: fixed window, sliding window, token bucket.",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --coverage --forceExit",
    "test:watch": "jest --watch",
    "example": "node examples/basic.js",
    "example:redis": "node examples/with-redis.js",
    "example:advanced": "node examples/advanced.js"
  },
  "keywords": [
    "express",
    "rate-limit",
    "rate-limiter",
    "middleware",
    "redis",
    "api",
    "throttle",
    "sliding-window",
    "token-bucket",
    "fixed-window"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "express": "^4.18.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 45,
        "functions": 50,
        "lines": 55,
        "statements": 55
      }
    }
  }
}
